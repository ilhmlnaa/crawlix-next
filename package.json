{
  "name": "crawlix-next",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --filter=@repo/api --filter=@repo/web --filter=@repo/worker",
    "dev:api": "pnpm --filter @repo/api start:dev",
    "dev:web": "pnpm --filter @repo/web dev",
    "dev:docs": "pnpm --filter @repo/docs dev",
    "dev:worker": "pnpm --filter @repo/worker start:dev",
    "dev:infra": "docker compose up -d rabbitmq redis",
    "build:api": "pnpm --filter @repo/api... build",
    "build:web": "pnpm --filter @repo/web... build",
    "build:docs": "pnpm --filter @repo/docs... build",
    "build:worker": "pnpm --filter @repo/worker... build",
    "start:api": "pnpm --filter @repo/api start",
    "start:web": "pnpm --filter @repo/web start",
    "start:docs": "pnpm --filter @repo/docs start",
    "start:worker": "pnpm --filter @repo/worker start",
    "pm2:start": "pm2 start ecosystem.config.js --env production",
    "pm2:start:api": "pm2 start ecosystem.config.js --only crawlix-api --env production",
    "pm2:start:worker": "pm2 start ecosystem.config.js --only crawlix-worker --env production",
    "pm2:start:web": "pm2 start ecosystem.config.js --only crawlix-web --env production",
    "pm2:restart:api": "pm2 restart crawlix-api",
    "pm2:restart:worker": "pm2 restart crawlix-worker",
    "pm2:restart:web": "pm2 restart crawlix-web",
    "pm2:logs": "pm2 logs",
    "pm2:save": "pm2 save",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md,yml,yaml}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.3",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
