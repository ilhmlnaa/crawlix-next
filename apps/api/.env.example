PORT=3001
CORS_ORIGIN=http://localhost:3000
API_SERVICE_NAME=crawlix-api
DASHBOARD_ORIGIN=http://localhost:3000
SESSION_SECRET=replace-with-strong-session-secret
SESSION_COOKIE_NAME=crawlix_session
SESSION_TTL_SECONDS=43200
DASHBOARD_ADMIN_EMAIL=admin@crawlix.local
DASHBOARD_ADMIN_PASSWORD=replace-with-strong-admin-password
API_KEY_PREFIX=cx
RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_QUEUE_NAME=crawlix.scrape.jobs
RABBITMQ_RETRY_QUEUE_NAME=crawlix.scrape.jobs.retry
RABBITMQ_DLQ_QUEUE_NAME=crawlix.scrape.jobs.dlq
RABBITMQ_RETRY_DELAY_MS=15000
RABBITMQ_MAX_DELIVERY_ATTEMPTS=3
REDIS_URL=redis://localhost:6379
REDIS_JOB_PREFIX=crawlix:jobs
RESULT_TTL_SECONDS=3600
SCRAPER_DEFAULT_STRATEGY=auto
SCRAPER_TIMEOUT_MS=30000
SCRAPER_CACHE_TTL_SECONDS=900
SCRAPER_MAX_RETRIES=2
