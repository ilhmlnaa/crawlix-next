# ------------------------------------------------------------------
# WORKER SERVICE
# Copy this file when deploying apps/worker separately.
# ------------------------------------------------------------------

# ------------------------------------------------------------------
# WORKER RUNTIME
# ------------------------------------------------------------------
WORKER_PORT=3002
# PORT=3002
WORKER_SERVICE_NAME=crawlix-worker

# ------------------------------------------------------------------
# SHARED INFRASTRUCTURE
# ------------------------------------------------------------------
RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_QUEUE_NAME=crawlix.scrape.jobs
RABBITMQ_RETRY_QUEUE_NAME=crawlix.scrape.jobs.retry
RABBITMQ_DLQ_QUEUE_NAME=crawlix.scrape.jobs.dlq
RABBITMQ_WEBHOOK_QUEUE_NAME=crawlix.scrape.webhooks
RABBITMQ_WEBHOOK_RETRY_QUEUE_NAME=crawlix.scrape.webhooks.retry
RABBITMQ_WEBHOOK_DLQ_QUEUE_NAME=crawlix.scrape.webhooks.dlq
RABBITMQ_RETRY_DELAY_MS=15000
RABBITMQ_MAX_DELIVERY_ATTEMPTS=3
RABBITMQ_WEBHOOK_RETRY_DELAY_MS=15000
RABBITMQ_WEBHOOK_MAX_DELIVERY_ATTEMPTS=5
REDIS_URL=redis://localhost:6379
REDIS_JOB_PREFIX=crawlix:jobs
RESULT_TTL_SECONDS=3600

# ------------------------------------------------------------------
# WEBHOOK DELIVERY
# ------------------------------------------------------------------
WEBHOOK_SIGNING_SECRET=replace-with-strong-webhook-signing-secret
WEBHOOK_REQUEST_TIMEOUT_MS=10000

# ------------------------------------------------------------------
# SCRAPER EXECUTION
# ------------------------------------------------------------------
SCRAPER_DEFAULT_STRATEGY=auto
SCRAPER_TIMEOUT_MS=30000
SCRAPER_CACHE_TTL_SECONDS=900
SCRAPER_MAX_RETRIES=2
SCRAPER_RETRY_DELAY_MS=1000
# Fallback proxy used only when job options.useProxy=true and options.proxyUrl is empty.
SCRAPER_PROXY_URL=
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_EXECUTABLE_PATH=
PLAYWRIGHT_BROWSER_IDLE_TIMEOUT_MS=120000
